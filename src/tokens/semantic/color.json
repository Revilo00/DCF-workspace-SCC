{
  "color": {
    "$type": "color",
    "background": {
      "default": { "$value": "{color.neutral.0}",   "$description": "Default page background" },
      "subtle":  { "$value": "{color.neutral.100}", "$description": "Subdued surface" },
      "inverse": { "$value": "{color.neutral.900}", "$description": "Inverted surface" }
    },
    "text": {
      "default": { "$value": "{color.neutral.900}" },
      "muted":   { "$value": "{color.neutral.500}" },
      "inverse": { "$value": "{color.neutral.0}" }
    },
    "action": {
      "primary":       { "$value": "{color.blue.500}", "$description": "Primary CTA" },
      "primary-hover": { "$value": "{color.blue.700}" },
      "primary-text":  { "$value": "{color.neutral.0}" }
    },
    "border": {
      "default": { "$value": "{color.neutral.300}" }
    }
  }
}
