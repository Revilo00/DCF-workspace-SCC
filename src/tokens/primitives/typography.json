{
  "font": {
    "family": {
      "$type": "fontFamily",
      "sans": { "$value": ["Inter", "system-ui", "sans-serif"] },
      "mono": { "$value": ["JetBrains Mono", "monospace"] }
    },
    "weight": {
      "$type": "fontWeight",
      "regular":  { "$value": 400 },
      "medium":   { "$value": 500 },
      "semibold": { "$value": 600 },
      "bold":     { "$value": 700 }
    },
    "size": {
      "$type": "dimension",
      "xs":   { "$value": "12px" },
      "sm":   { "$value": "14px" },
      "base": { "$value": "16px" },
      "lg":   { "$value": "20px" },
      "xl":   { "$value": "24px" },
      "2xl":  { "$value": "32px" }
    },
    "lineHeight": {
      "$type": "number",
      "tight":   { "$value": 1.25 },
      "normal":  { "$value": 1.5 },
      "relaxed": { "$value": 1.75 }
    }
  }
}
